datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl= env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SuperAdmin
  SchoolAdmin
  Teacher
  Student
}

enum SubscriptionPlan {
  Free
  Plus
  Premium
}

enum SubscriptionStatus {
  Active
  Suspended
  Expired
}

enum StudentStatus {
  Active
  Graduated
  Archived
  Suspended
}

enum Gender {
  Male
  Female
}

enum TermNumber {
  First
  Second
  Third
}

enum ResultStatus {
  Draft
  Submitted
  Approved
  Published
}

enum Grade {
  A
  B
  C
  D
  E
  F
}

enum PaymentStatus {
  Pending
  Cleared
  Rejected
}

enum AnnouncementAudience {
  All
  Students
  Teachers
  Class
}

model School {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String             @db.VarChar(200)
  address            String             @default("") @db.VarChar(500)
  contactEmail       String             @unique @db.VarChar(150)
  contactPhone       String             @default("") @db.VarChar(30)
  logoUrl            String             @default("") @db.VarChar(500)
  schoolType         String?            @db.VarChar(100)
  city               String?            @db.VarChar(100)
  state              String?            @db.VarChar(100)
  country            String?            @db.VarChar(100)
  studentCount       Int?
  slug               String             @unique @db.VarChar(200)
  subscriptionPlan   SubscriptionPlan   @default(Free)
  subscriptionStatus SubscriptionStatus @default(Active)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime?          @updatedAt
  planId             String?            @db.Uuid
  subscriptionEndedAt DateTime?
  paystackSubscriptionCode String?      @db.VarChar(150)
  paystackCustomerCode     String?      @db.VarChar(150)
  paystackEmailToken       String?      @db.VarChar(150)

  plan             PaymentPlan?       @relation(fields: [planId], references: [id], onDelete: SetNull)

  users            User[]
  students         Student[]
  teachers         Teacher[]
  classes          Class[]
  subjects         Subject[]
  academicSessions AcademicSession[]
  gradingRules     GradingRule[]
  scores           Score[]
  results          Result[]
  feePayments      FeePayment[]
  announcements    Announcement[]
  attendances      Attendance[]
  parents          Parent[]
}

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  schoolId           String?            @db.Uuid
  name               String             @default("") @db.VarChar(150)
  email              String             @unique @db.VarChar(200)
  passwordHash       String
  role               UserRole
  profilePictureUrl  String             @default("") @db.VarChar(500)
  isActive           Boolean            @default(true)
  refreshToken       String?
  refreshTokenExpiry DateTime?
  lastLogin              DateTime?
  adminRole              String?            @db.VarChar(100)
  passwordResetToken     String?
  passwordResetExpiry    DateTime?
  isVerified             Boolean            @default(true)
  verificationOtp        String?            @db.VarChar(10)
  verificationOtpExpiry  DateTime?
  createdAt              DateTime           @default(now())

  school             School?            @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  students           Student[]          @relation("UserToStudent")
  teachers           Teacher[]          @relation("UserToTeacher")
  clearedFeePayments FeePayment[]       @relation("UserToClearedByUser")
  announcements      Announcement[]     @relation("UserToAnnouncement")
}

model Parent {
  id                String    @id @default(uuid()) @db.Uuid
  schoolId          String    @db.Uuid
  fullName          String    @db.VarChar(200)
  email             String    @db.VarChar(200)
  phone             String    @default("") @db.VarChar(30)
  passportUrl       String    @default("") @db.VarChar(500)
  idNumber          String    @default("") @db.VarChar(100)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime? @updatedAt

  school            School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students          Student[]

  @@unique([schoolId, email])
  @@index([schoolId])
}

model Student {
  id                String        @id @default(uuid()) @db.Uuid
  schoolId          String        @db.Uuid
  classId           String?       @db.Uuid
  userId            String?       @db.Uuid
  parentId          String?       @db.Uuid
  fullName          String        @db.VarChar(200)
  admissionNumber   String        @db.VarChar(50)
  gender            Gender
  dateOfBirth       DateTime?     @db.Date
  profilePictureUrl String        @default("") @db.VarChar(500)
  status            StudentStatus @default(Active)
  suspendedBySubscription Boolean @default(false)
  arm               String?       @db.VarChar(50)
  bloodGroup        String?       @db.VarChar(20)
  enrolledAt        DateTime      @default(now())

  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class           Class?        @relation(fields: [classId], references: [id], onDelete: SetNull)
  user            User?         @relation("UserToStudent", fields: [userId], references: [id], onDelete: SetNull)
  parent          Parent?       @relation(fields: [parentId], references: [id], onDelete: SetNull)
  scores          Score[]
  results         Result[]
  feePayments     FeePayment[]
  attendances     Attendance[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
}

model Teacher {
  id                String    @id @default(uuid()) @db.Uuid
  schoolId          String    @db.Uuid
  userId            String    @db.Uuid
  fullName          String    @db.VarChar(200)
  email             String    @default("") @db.VarChar(200)
  phone             String    @default("") @db.VarChar(30)
  profilePictureUrl String    @default("") @db.VarChar(500)
  isActive          Boolean   @default(true)
  suspendedBySubscription Boolean @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime? @updatedAt

  school             School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user               User                      @relation("UserToTeacher", fields: [userId], references: [id], onDelete: Cascade)
  subjectAssignments TeacherSubjectAssignment[]
  enteredScores      Score[]
  formClasses        Class[]                   @relation("ClassFormTeacher")
  takenAttendances   Attendance[]

  @@index([schoolId])
}

model Class {
  id                String    @id @default(uuid()) @db.Uuid
  schoolId          String    @db.Uuid
  academicSessionId String?   @db.Uuid
  formTeacherId     String?   @db.Uuid
  name              String    @db.VarChar(100)
  arm               String    @default("") @db.VarChar(50)
  level             Int       @default(1)
  createdAt         DateTime  @default(now())

  school             School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicSession    AcademicSession?          @relation(fields: [academicSessionId], references: [id], onDelete: SetNull)
  formTeacher        Teacher?                  @relation("ClassFormTeacher", fields: [formTeacherId], references: [id], onDelete: SetNull)
  students           Student[]
  teacherAssignments TeacherSubjectAssignment[]
  classSubjects      ClassSubject[]
  scores             Score[]
  results            Result[]
  attendances        Attendance[]

  @@index([schoolId])
}

model Subject {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  name      String   @db.VarChar(200)
  code      String   @default("") @db.VarChar(50)
  createdAt DateTime @default(now())

  school             School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherAssignments TeacherSubjectAssignment[]
  classSubjects      ClassSubject[]
  scores             Score[]

  @@unique([schoolId, name])
}

model AcademicSession {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @db.Uuid
  name      String    @db.VarChar(100)
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  isCurrent Boolean   @default(false)
  createdAt DateTime  @default(now())

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes     Class[]
  terms       Term[]
  scores      Score[]
  results     Result[]
  feePayments FeePayment[]

  @@index([schoolId])
}

model Term {
  id                String     @id @default(uuid()) @db.Uuid
  academicSessionId String     @db.Uuid
  termNumber        TermNumber
  startDate         DateTime   @db.Date
  endDate           DateTime   @db.Date
  isCurrent         Boolean    @default(false)
  resultsPublished  Boolean    @default(false)
  createdAt         DateTime   @default(now())

  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  scores          Score[]
  results         Result[]
  feePayments     FeePayment[]

  @@unique([academicSessionId, termNumber])
}

model TeacherSubjectAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @db.Uuid
  subjectId String   @db.Uuid
  classId   String   @db.Uuid
  assignedAt DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId, classId])
}

model ClassSubject {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @db.Uuid
  subjectId String   @db.Uuid
  assignedAt DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
}

model GradingRule {
  id       String @id @default(uuid()) @db.Uuid
  schoolId String @db.Uuid
  grade    Grade
  minScore Int
  maxScore Int
  remark   String @default("") @db.VarChar(100)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, grade])
}

model Score {
  id                 String   @id @default(uuid()) @db.Uuid
  schoolId           String   @db.Uuid
  studentId          String   @db.Uuid
  subjectId          String   @db.Uuid
  classId            String   @db.Uuid
  termId             String   @db.Uuid
  academicSessionId  String   @db.Uuid
  firstCA            Decimal  @db.Decimal(5, 2)
  secondCA           Decimal  @db.Decimal(5, 2)
  exam               Decimal  @db.Decimal(5, 2)
  total              Decimal  @db.Decimal(6, 2)
  grade              Grade
  remark             String   @default("") @db.VarChar(200)
  enteredByTeacherId String?  @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime? @updatedAt

  school           School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student          Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject          Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class            Class           @relation(fields: [classId], references: [id], onDelete: NoAction)
  term             Term            @relation(fields: [termId], references: [id], onDelete: NoAction)
  academicSession  AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: NoAction)
  enteredByTeacher Teacher?        @relation(fields: [enteredByTeacherId], references: [id], onDelete: SetNull)

  @@unique([schoolId, studentId, subjectId, termId])
  @@index([schoolId, classId, subjectId, termId])
}

model Result {
  id                String       @id @default(uuid()) @db.Uuid
  schoolId          String       @db.Uuid
  studentId         String       @db.Uuid
  classId           String       @db.Uuid
  termId            String       @db.Uuid
  academicSessionId String       @db.Uuid
  totalScore        Decimal      @db.Decimal(8, 2)
  average           Decimal      @db.Decimal(6, 2)
  position          Int
  subjectCount      Int
  status            ResultStatus @default(Draft)
  teacherComment    String       @default("") @db.VarChar(500)
  adminComment      String       @default("") @db.VarChar(500)
  submittedAt       DateTime?
  approvedAt        DateTime?
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime?    @updatedAt

  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class           Class           @relation(fields: [classId], references: [id], onDelete: NoAction)
  term            Term            @relation(fields: [termId], references: [id], onDelete: NoAction)
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: NoAction)

  @@unique([schoolId, studentId, termId])
  @@index([schoolId, classId, termId])
}

model FeePayment {
  id                String        @id @default(uuid()) @db.Uuid
  schoolId          String        @db.Uuid
  studentId         String        @db.Uuid
  termId            String        @db.Uuid
  academicSessionId String        @db.Uuid
  amountDue         Decimal       @db.Decimal(12, 2)
  amountPaid        Decimal       @db.Decimal(12, 2)
  status            PaymentStatus @default(Pending)
  clearedByUserId   String?       @db.Uuid
  clearedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime?     @updatedAt

  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term            Term            @relation(fields: [termId], references: [id], onDelete: NoAction)
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: NoAction)
  clearedByUser   User?           @relation("UserToClearedByUser", fields: [clearedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, studentId, termId])
}

model Announcement {
  id             String               @id @default(uuid()) @db.Uuid
  schoolId       String               @db.Uuid
  createdByUserId String              @db.Uuid
  title          String               @db.VarChar(300)
  content        String               @db.Text
  audience       AnnouncementAudience @default(All)
  targetClassId  String?              @db.Uuid
  createdAt      DateTime             @default(now())

  school         School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdByUser  User                 @relation("UserToAnnouncement", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

enum AttendanceStatus {
  Present
  Absent
  Late
}

model Attendance {
  id                String           @id @default(uuid()) @db.Uuid
  schoolId          String           @db.Uuid
  classId           String           @db.Uuid
  studentId         String           @db.Uuid
  date              DateTime         @db.Date
  status            AttendanceStatus
  remarks           String           @default("") @db.VarChar(200)
  takenByTeacherId  String?          @db.Uuid
  createdAt         DateTime         @default(now())
  updatedAt         DateTime?        @updatedAt

  school            School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class             Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  takenByTeacher    Teacher?         @relation(fields: [takenByTeacherId], references: [id], onDelete: SetNull)

  @@unique([schoolId, studentId, date])
  @@index([schoolId, classId, date])
}

model PaymentPlan {
  id               String       @id @default(uuid()) @db.Uuid
  name             String       @unique @db.VarChar(150)
  amount           Decimal      @db.Decimal(12, 2)
  maxTeachers      Int
  maxStudents      Int
  isActive         Boolean      @default(true)
  paystackPlanCode String?      @db.VarChar(150)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime?    @updatedAt

  schools          School[]
}


